data/*.sqlite
data/*.sqlite-journal
data/*.sqlite-wal
data/*.sqlite-shm

# Shared-secret auth token (auto-generated by auth.php) + its grace-mode log --
# local dev's copy of what prod keeps in its private dir, outside the web root.
data/auth.config.php
data/auth.log

# Deploy script artifacts -- never commit (deploy.config.json holds FTPS creds)
deploy.config.json
deploy.log
deploy.winscp.log
dist/

# .NET build output
bin/
obj/

# CcswAgent local config -- machine name is per-box, never committed
agent/CcswAgent/agent.config.json

# CcswPopup local config -- relayBase is per-box, never committed
popup/CcswPopup/popup.config.json

# ccsw-relay local config -- port/tunnelToken/publicUrl are per-box, never committed
relay.config.json

# Editor/manual backups -- these shadow gitignored config files (e.g.
# deploy.config.json.bak) and would smuggle their credentials past the
# ignore rule for the original.
*.bak

# Build-session transcripts -- contain infra details, moved out of repo
human_msgs.txt
assistant_msgs.txt
tool_use.txt

# Board layout-verification screenshots (Playwright) -- local reference only
board/_accordion_shots/

# Provisioning artifacts served by download.php -- agent-win.zip is a BUILD of
# agent/CcswAgent (the .NET output), rebuilt and re-pushed on demand, so it is
# deploy input, not source. Kept out of git for the usual reason binaries are:
# it would bloat every clone and go stale against the code beside it.
# The dir's .htaccess IS tracked (negated below) -- it is what denies direct
# access to the zip, so it must ship with the deploy.
board/downloads/*
!board/downloads/.htaccess
